---

const { title, description, url, page, icon } = Astro.props

---

<div class="group relative">
    <a href={url} target="_blank" rel="noopener noreferrer" class="opacity-0 z-10 transition-opacity cursor-pointer duration-150 group-hover:opacity-100 w-full absolute inset-0 flex items-center justify-center gap-2">
        <i class="ph-fill ph-arrow-square-out"/>
        <span class="text-sm font-bold">Open on {page}</span>
    </a>
    <div class="flex flex-col gap-1 transition-all duration-200 md:group-hover:blur-2xl">
        <div class="flex flex-row items-center gap-2">
            <i class={icon ? `ph text-lg ${icon}` : 'ph ph-github-logo'}/>
            <span class="font-bold">{title}</span>
        </div>
        <span class="text-sm opacity-40 text-justify">{description}</span>
    </div>
</div>